{"id":"self-corrected-latent-rewards","title":"Self-Corrected Image Generation with Explainable Latent Rewards","venue":"arXiv 2026","task":"alignment-safety","summary":"A reward-driven self-correction method that edits latent trajectories using interpretable feedback signals.","paper":"https://arxiv.org/abs/2603.24965"}
{"id":"dtvi","title":"DTVI: Dual-Stage Textual and Visual Intervention for Safe Text-to-Image Generation","venue":"arXiv 2026","task":"alignment-safety","summary":"A two-stage safeguard that intervenes on both prompt and visual generation pathways for safer T2I outputs.","paper":"https://arxiv.org/abs/2603.22041"}

# personalization
{"id":"para","title":"PaRa: Personalizing Text-to-Image Diffusion via Parameter Rank Reduction","venue":"ICLR 2025","task":"personalization","summary":"A rank-reduction personalization method that improves subject fidelity while preserving editability and parameter efficiency.","paper":"https://arxiv.org/abs/2406.05641"}
