# controllable-generation
{"id":"precisecam","title":"PreciseCam: Precise Camera Control for Text-to-Image Generation","venue":"CVPR 2025","task":"controllable-generation","summary":"A camera-conditioned generation method that gives explicit control over extrinsics and intrinsics instead of relying on prompt hacks.","paper":"https://arxiv.org/abs/2501.12910","homepage":"https://graphics.unizar.es/projects/PreciseCam2024"}
{"id":"type-r","title":"Type-R: Automatically Retouching Typos for Text-to-Image Generation","venue":"CVPR 2025","task":"controllable-generation","summary":"A post-generation correction pipeline that detects, removes, and re-renders text regions to improve text spelling in generated images.","paper":"https://arxiv.org/abs/2411.18159"}
{"id":"compass-control","title":"Compass Control: Multi Object Orientation Control for Text-to-Image Generation","venue":"CVPR 2025","task":"controllable-generation","summary":"Introduces orientation-aware compass tokens for explicit multi-object pose control in text-to-image diffusion models.","paper":"https://arxiv.org/abs/2504.06752"}
{"id":"generative-photography","title":"Generative Photography: Scene-Consistent Camera Control for Realistic Text-to-Image Synthesis","venue":"CVPR 2025","task":"controllable-generation","summary":"A physically grounded camera-control framework for scene-consistent changes in focal length and viewpoint during image synthesis.","paper":"https://arxiv.org/abs/2412.02168"}
{"id":"make-it-count","title":"Make It Count: Text-to-Image Generation with an Accurate Number of Objects","venue":"CVPR 2025","task":"controllable-generation","summary":"Targets count fidelity by detecting over- and under-generation during denoising and correcting missing instances.","paper":"https://arxiv.org/abs/2406.10210"}
{"id":"mccd","title":"MCCD: Multi-Agent Collaboration-based Compositional Diffusion for Complex Text-to-Image Generation","venue":"CVPR 2025","task":"controllable-generation","summary":"A training-free multi-agent prompting and regional refinement framework for complex compositional image generation.","paper":"https://arxiv.org/abs/2505.02648"}
{"id":"shapewords","title":"ShapeWords: Guiding Text-to-Image Synthesis with 3D Shape-Aware Prompts","venue":"CVPR 2025","task":"controllable-generation","summary":"Injects 3D shape information as specialized prompt tokens to improve geometry-aware image generation.","paper":"https://arxiv.org/abs/2412.02912"}
{"id":"focus-n-fix","title":"Focus-N-Fix: Region-Aware Fine-Tuning for Text-to-Image Generation","venue":"CVPR 2025","task":"controllable-generation","summary":"A localized fine-tuning method that corrects only problematic regions while preserving the rest of the image behavior.","paper":"https://arxiv.org/abs/2501.06481"}
{"id":"silmm","title":"SILMM: Self-Improving Large Multimodal Models for Compositional Text-to-Image Generation","venue":"CVPR 2025","task":"controllable-generation","summary":"Uses scalable self-feedback and preference optimization to improve compositional text-image alignment in large multimodal models.","paper":"https://arxiv.org/abs/2412.05818"}
{"id":"progressive-compositionality","title":"Progressive Compositionality in Text-to-Image Generative Models","venue":"ICLR 2025","task":"controllable-generation","summary":"Builds a hard-negative curriculum and contrastive learning pipeline to improve compositional reasoning in T2I models.","paper":"https://arxiv.org/abs/2410.16719"}
{"id":"lgtm","title":"LGTM: Training-Free Light-Guided Text-to-Image Diffusion Model via Initial Noise Manipulation","venue":"arXiv 2026","task":"controllable-generation","summary":"A training-free method that steers lighting effects by directly manipulating the initial diffusion noise.","paper":"https://arxiv.org/abs/2603.24086"}
{"id":"spatialreward","title":"SpatialReward: Verifiable Spatial Reward Modeling for Fine-Grained Spatial Consistency in Text-to-Image Generation","venue":"arXiv 2026","task":"controllable-generation","summary":"Introduces verifiable reward modeling for spatial relations to improve fine-grained layout consistency in T2I outputs.","paper":"https://arxiv.org/abs/2603.22228"}
