{"id":"primitiveanything","title":"PrimitiveAnything: Human-Crafted 3D Primitive Assembly Generation with Auto-Regressive Transformer","venue":"SIGGRAPH 2025","task":"articulated-asset","summary":"Learns human-like primitive abstractions and assemblies for editable structured 3D assets.","paper":"https://arxiv.org/abs/2505.04622","homepage":"https://primitiveanything.github.io"}
{"id":"omnipart","title":"OmniPart: Part-Aware 3D Generation with Semantic Decoupling and Structural Cohesion","venue":"arXiv 2025","task":"part-aware-generation","summary":"A two-stage part planning and part synthesis framework for editable and controllable 3D assets.","paper":"https://arxiv.org/abs/2507.06165"}
{"id":"partcrafter","title":"PartCrafter: Structured 3D Mesh Generation via Compositional Latent Diffusion Transformers","venue":"arXiv 2025","task":"part-aware-generation","summary":"A compositional latent DiT that jointly denoises multiple semantic parts into decomposable 3D meshes.","paper":"https://arxiv.org/abs/2506.05573"}
{"id":"infinite-mobility","title":"Infinite Mobility: Scalable High-Fidelity Synthesis of Articulated Objects via Procedural Generation","venue":"arXiv 2025","task":"articulated-asset","summary":"A procedural articulated-object synthesis pipeline built for scale, fidelity, and simulation usefulness.","paper":"https://arxiv.org/abs/2503.13424","repo":"https://github.com/Intern-Nexus/Infinite-Mobility","open_source":true}
