# agentic-scene-generation
{"id":"scenex","title":"SceneX: Procedural Controllable Large-scale Scene Generation","venue":"AAAI 2025","task":"agentic-scene-generation","summary":"An LLM-assisted procedural generation framework for controllable large-scale scene creation in Blender-style pipelines.","paper":"https://arxiv.org/abs/2403.15698"}
{"id":"3d-gpt","title":"3D-GPT: Procedural 3D Modeling with Large Language Models","venue":"3DV 2025","task":"agentic-scene-generation","summary":"An early but still relevant LLM-driven procedural 3D modeling framework for scene and asset construction.","paper":"https://arxiv.org/abs/2310.12945"}
{"id":"latticeworld","title":"LatticeWorld: A Multimodal Large Language Model-Empowered Framework for Interactive Complex World Generation","venue":"arXiv 2025","task":"agentic-scene-generation","summary":"An MLLM-plus-engine framework for interactive large-scale world generation with dynamic agents and physics.","paper":"https://arxiv.org/abs/2509.05263"}
{"id":"sceneweaver","title":"SceneWeaver: All-in-One 3D Scene Synthesis with an Extensible and Self-Reflective Agent","venue":"NeurIPS 2025","task":"agentic-scene-generation","summary":"A reflective agent that plans, evaluates, and repairs 3D scenes by invoking an extensible toolchain.","paper":"https://arxiv.org/abs/2509.20414","homepage":"https://scene-weaver.github.io/"}
{"id":"scenethesis","title":"Scenethesis: A Language and Vision Agentic Framework for 3D Scene Generation","venue":"arXiv 2025","task":"agentic-scene-generation","summary":"Combines LLM planning with vision-guided refinement to produce more realistic and physically plausible 3D scenes.","paper":"https://arxiv.org/abs/2505.02836"}

# indoor / layout-to-scene / scene-editing
{"id":"hs-openvocab-indoor-scene","title":"Hierarchically-Structured Open-Vocabulary Indoor Scene Synthesis with Pre-trained Large Language Model","venue":"AAAI 2025","task":"indoor","summary":"Generates hierarchical scene descriptions and optimizes them into feasible indoor layouts for open-vocabulary room synthesis.","paper":"https://arxiv.org/abs/2502.10675","domain":["indoor"]}
{"id":"global-local-tree-search-vlms","title":"Global-Local Tree Search in VLMs for 3D Indoor Scene Generation","venue":"CVPR 2025","task":"indoor","summary":"Frames indoor scene synthesis as a global-local search problem over placements using VLMs as the planner.","paper":"https://arxiv.org/abs/2503.18476","domain":["indoor"]}
{"id":"layoutvlm","title":"LayoutVLM: Differentiable Optimization of 3D Layout via Vision-Language Models","venue":"CVPR 2025","task":"layout-to-scene","summary":"Uses a differentiable scene-layout representation and VLM supervision to improve open-universe 3D layout generation.","paper":"https://arxiv.org/abs/2412.02193","domain":["indoor"]}
{"id":"roomcraft","title":"RoomCraft: Controllable and Complete 3D Indoor Scene Generation","venue":"arXiv 2025","task":"indoor","summary":"A controllable indoor scene generator focused on both completeness and realistic arrangement.","paper":"https://arxiv.org/abs/2506.22291","domain":["indoor"]}
{"id":"respace","title":"ReSpace: Text-Driven 3D Scene Synthesis and Editing with Preference Alignment","venue":"arXiv 2025","task":"scene-editing","summary":"A language-model-based indoor scene synthesis and editing framework with explicit preference alignment.","paper":"https://arxiv.org/abs/2506.02459","domain":["indoor"]}
