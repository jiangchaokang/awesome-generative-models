{"id":"hlg","title":"HLG: Comprehensive 3D Room Construction via Hierarchical Layout Generation","venue":"arXiv 2025","task":"layout-to-scene","summary":"A coarse-to-fine hierarchical layout generator for more detailed and physically plausible room construction.","paper":"https://arxiv.org/abs/2508.17832","domain":["indoor"]}
