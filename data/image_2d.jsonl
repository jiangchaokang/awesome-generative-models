{"id":"relevance-feedback-t2i","title":"Relevance Feedback in Text-to-Image Diffusion: A Training-Free And Model-Agnostic Interactive Framework","venue":"arXiv 2026","task":"controllable-generation","summary":"An interactive relevance-feedback loop for refining generations without retraining the underlying diffusion model.","paper":"https://arxiv.org/abs/2603.14936"}

# alignment-safety
{"id":"text-embedding-not-all-you-need","title":"Text Embedding is Not All You Need: Attention Control for Text-to-Image Semantic Alignment with Text Self-Attention Maps","venue":"CVPR 2025","task":"alignment-safety","summary":"Transfers syntactic relations from text self-attention to cross-attention to improve semantic binding and prompt faithfulness.","paper":"https://arxiv.org/abs/2411.15236"}
{"id":"dual-space-concept-control","title":"Plug-and-Play Interpretable Responsible Text-to-Image Generation via Dual-Space Multi-facet Concept Control","venue":"CVPR 2025","task":"alignment-safety","summary":"A plug-and-play responsible generation framework that jointly controls multiple safety and fairness facets with interpretable mechanisms.","paper":"https://arxiv.org/abs/2503.18324"}
{"id":"noise-diffusion","title":"Noise Diffusion for Enhancing Semantic Faithfulness in Text-to-Image Synthesis","venue":"CVPR 2025","task":"alignment-safety","summary":"Optimizes the initial noisy latent with LVLM guidance to improve prompt-image semantic fidelity across diffusion models.","paper":"https://arxiv.org/abs/2411.16503","repo":"https://github.com/Bomingmiao/NoiseDiffusion","open_source":true}
{"id":"improving-long-text-alignment","title":"Improving Long-Text Alignment for Text-to-Image Diffusion Models","venue":"ICLR 2025","task":"alignment-safety","summary":"A long-text encoding and decomposed preference-optimization framework for better alignment to lengthy prompts.","paper":"https://arxiv.org/abs/2410.11817","repo":"https://github.com/luping-liu/LongAlign","open_source":true}
