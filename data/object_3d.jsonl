# 3d-shape-generation
{"id":"trellis","title":"TRELLIS: Structured 3D Latents for Scalable and Versatile 3D Generation","venue":"CVPR 2025","task":"3d-shape-generation","summary":"A large-scale unified latent representation for text- and image-conditioned 3D asset generation across multiple output formats.","paper":"https://arxiv.org/abs/2412.01506","repo":"https://github.com/microsoft/TRELLIS","open_source":true,"homepage":"https://microsoft.github.io/TRELLIS/"}
{"id":"lagem","title":"LaGeM: A Large Geometry Model for 3D Representation Learning and Diffusion","venue":"ICLR 2025","task":"3d-shape-generation","summary":"A hierarchical geometry autoencoder and cascaded diffusion pipeline for scalable high-fidelity 3D generation.","paper":"https://arxiv.org/abs/2410.01295"}
{"id":"ultrashape","title":"UltraShape 1.0: High-Fidelity 3D Shape Generation via Scalable Geometric Refinement","venue":"arXiv 2025","task":"3d-shape-generation","summary":"A two-stage geometry generation pipeline emphasizing high-resolution local refinement and strong watertight processing.","paper":"https://arxiv.org/abs/2512.21185"}
{"id":"lattice-3d","title":"LATTICE: Democratize High-Fidelity 3D Generation at Scale","venue":"arXiv 2025","task":"3d-shape-generation","summary":"A scalable two-stage 3D asset generator built on structured voxel-set latents and rectified-flow transformers.","paper":"https://arxiv.org/abs/2512.03052"}
{"id":"unilat3d","title":"UniLat3D: Geometry-Appearance Unified Latents for Single-Stage 3D Generation","venue":"arXiv 2025","task":"3d-shape-generation","summary":"Unifies geometry and appearance in one latent space so 3D assets can be generated in a single stage.","paper":"https://arxiv.org/abs/2509.25079"}
{"id":"ultra3d","title":"Ultra3D: Efficient and High-Fidelity 3D Generation with Part Attention","venue":"arXiv 2025","task":"3d-shape-generation","summary":"Introduces geometry-aware part attention for faster high-resolution 3D generation without losing detail.","paper":"https://arxiv.org/abs/2507.17745"}
{"id":"sparc3d","title":"Sparc3D: Sparse Representation and Construction for High-Resolution 3D Shapes Modeling","venue":"NeurIPS 2025","task":"3d-shape-generation","summary":"A sparse deformable marching-cubes representation plus sparse-conv VAE for near-lossless high-resolution 3D generation.","paper":"https://arxiv.org/abs/2505.14521","repo":"https://github.com/lizhihao6/Sparc3D","open_source":true,"homepage":"https://lizhihao6.github.io/Sparc3D"}
{"id":"octgpt","title":"OctGPT: Octree-based Multiscale Autoregressive Models for 3D Shape Generation","venue":"SIGGRAPH 2025","task":"3d-shape-generation","summary":"A multiscale octree autoregressive model that makes high-resolution 3D generation far more efficient.","paper":"https://arxiv.org/abs/2504.09975"}
{"id":"sparseflex","title":"SparseFlex: High-Resolution and Arbitrary-Topology 3D Shape Modeling","venue":"arXiv 2025","task":"3d-shape-generation","summary":"A sparse-structured differentiable mesh representation that supports arbitrary topology and high-resolution 3D generation.","paper":"https://arxiv.org/abs/2503.21732"}
{"id":"octfusion","title":"OctFusion: Octree-based Diffusion Models for 3D Shape Generation","venue":"SGP 2025","task":"3d-shape-generation","summary":"An octree latent representation plus unified multi-scale diffusion model for fast high-quality shape generation.","paper":"https://arxiv.org/abs/2408.14732","repo":"https://github.com/octree-nn/octfusion","open_source":true}
{"id":"squeeze3d","title":"Squeeze3D: Your 3D Generation Model is Secretly an Extreme Neural Compressor","venue":"arXiv 2025","task":"3d-shape-generation","summary":"Repurposes pretrained 3D generators as powerful implicit compressors for meshes, point clouds, and radiance fields.","paper":"https://arxiv.org/abs/2506.07932"}
{"id":"slat-phys","title":"SLAT-Phys: Fast Material Property Field Prediction from Structured 3D Latents","venue":"arXiv 2026","task":"3d-shape-generation","summary":"Extends structured 3D latents from geometry toward material-property prediction for simulation-ready assets.","paper":"https://arxiv.org/abs/2603.23973"}

# point-cloud / image-to-3d / text-to-3d
{"id":"topodit-3d","title":"TopoDiT-3D: Topology-Aware Diffusion Transformer with Bottleneck Structure for 3D Point Cloud Generation","venue":"arXiv 2025","task":"3d-shape-generation","summary":"Injects persistent-homology topology cues into diffusion transformers for better point-cloud generation.","paper":"https://arxiv.org/abs/2505.09140","repo":"https://github.com/Zechao-Guan/TopoDiT-3D","open_source":true}
{"id":"pointcloud-ar-upsampling","title":"3D Point Cloud Generation via Autoregressive Up-sampling","venue":"arXiv 2025","task":"3d-shape-generation","summary":"Treats point-cloud generation as progressive next-scale up-sampling rather than flat-token prediction.","paper":"https://arxiv.org/abs/2503.08594"}
{"id":"eagle","title":"EAGLE: Contextual Point Cloud Generation via Adaptive Continuous Normalizing Flow with Self-Attention","venue":"arXiv 2025","task":"3d-shape-generation","summary":"A flow-based point-cloud generator that augments continuous normalizing flows with global self-attention.","paper":"https://arxiv.org/abs/2503.13479"}
{"id":"not-so-optimal-transport-flows","title":"Not-So-Optimal Transport Flows for 3D Point Cloud Generation","venue":"arXiv 2025","task":"3d-shape-generation","summary":"An approximate-OT flow model designed to scale better and train more easily on large point clouds.","paper":"https://arxiv.org/abs/2502.12456"}
{"id":"rgb2point","title":"RGB2Point: 3D Point Cloud Generation from Single RGB Images","venue":"ACM MM 2024","task":"image-to-3d","summary":"A transformer-based single-image point-cloud generator that stayed useful in 2025 as a strong lightweight baseline.","paper":"https://arxiv.org/abs/2407.14979","active_since":2025,"scope_note":"Kept as a still-active lightweight image-to-point-cloud baseline used in 2025 comparisons."}
{"id":"assetformer","title":"AssetFormer: Modular 3D Assets Generation with Autoregressive Transformer","venue":"arXiv 2026","task":"text-to-3d","summary":"Targets modular assets directly with autoregressive generation over part-aware structures.","paper":"https://arxiv.org/abs/2602.12100","repo":"https://github.com/Advocate99/AssetFormer","open_source":true}
{"id":"fuse3d","title":"Fuse3D: Generating 3D Assets Controlled by Multi-Image Fusion","venue":"arXiv 2026","task":"image-to-3d","summary":"A multi-image control framework for generating one fused 3D asset with region-level guidance.","paper":"https://arxiv.org/abs/2602.17040","homepage":"https://jinnmnm.github.io/Fuse3d.github.io/"}
{"id":"text-image-conditioned-3d-generation","title":"Text-Image Conditioned 3D Generation","venue":"arXiv 2026","task":"text-to-3d","summary":"A joint text-and-image conditioned 3D generation framework aimed at stronger controllability over asset content.","paper":"https://arxiv.org/abs/2603.21295"}

# foundation-3d-models / image-to-3d anchors active in 2025+
