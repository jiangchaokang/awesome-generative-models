{"id":"worldmesh","title":"WorldMesh: Generating Navigable Multi-Room 3D Scenes via Mesh-Conditioned Image Diffusion","venue":"arXiv 2026","task":"general-scene-generation","summary":"A mesh-conditioned image-diffusion route to multi-room navigable 3D scene generation.","paper":"https://arxiv.org/abs/2603.22972"}
{"id":"oneworld","title":"OneWorld: Taming Scene Generation with 3D Unified Representation Autoencoder","venue":"arXiv 2026","task":"general-scene-generation","summary":"Uses a unified 3D representation autoencoder to reduce the cross-view inconsistency of scene generation.","paper":"https://arxiv.org/abs/2603.16099"}
