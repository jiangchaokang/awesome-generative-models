{"id":"flashvdm","title":"Unleashing Vecset Diffusion Model for Fast Shape Generation","venue":"ICCV 2025","task":"3d-shape-generation","summary":"FlashVDM introduces progressive flow distillation and engineering optimizations to cut native 3D shape generation latency down to seconds while preserving quality.","paper":"https://arxiv.org/abs/2503.16302","repo":"https://github.com/Tencent-Hunyuan/FlashVDM","open_source":true,"orgs":["Tencent Hunyuan"]}
{"id":"hunyuan3d-2.5","title":"Hunyuan3D 2.5: Towards High-Fidelity 3D Assets Generation with Ultimate Details","venue":"arXiv 2025","task":"3d-shape-generation","summary":"A 2.5-generation upgrade emphasizing finer geometry, stronger textures, and better asset readiness for downstream use.","paper":"https://arxiv.org/abs/2506.16504"}
{"id":"triposr","title":"TripoSR: Fast 3D Object Reconstruction from a Single Image","venue":"arXiv 2024","task":"image-to-3d","summary":"A fast feed-forward single-image 3D reconstruction model that remained actively used in 2025 pipelines and baselines.","paper":"https://arxiv.org/abs/2403.02151","repo":"https://github.com/VAST-AI-Research/TripoSR","open_source":true,"active_since":2025,"scope_note":"Kept because TripoSR remained a widely used image-to-3D feed-forward baseline in 2025."}
{"id":"instantmesh","title":"InstantMesh: Efficient 3D Mesh Generation from a Single Image with Sparse-view Large Reconstruction Models","venue":"arXiv 2024","task":"image-to-3d","summary":"A highly practical single-image mesh generator that continued to be heavily used in 2025 open workflows.","paper":"https://arxiv.org/abs/2404.07191","repo":"https://github.com/TencentARC/InstantMesh","open_source":true,"active_since":2025,"scope_note":"Kept because InstantMesh remained one of the most used open image-to-mesh baselines in 2025."}
{"id":"unique3d","title":"Unique3D: High-Quality and Efficient 3D Mesh Generation from a Single Image","venue":"arXiv 2024","task":"image-to-3d","summary":"A strong multi-level diffusion image-to-3D mesh baseline that stayed active in 2025 open 3D asset pipelines.","paper":"https://arxiv.org/abs/2405.20343","repo":"https://github.com/AiuniAI/Unique3D","open_source":true,"active_since":2025,"scope_note":"Kept because Unique3D continued to be used as a strong open image-to-3D baseline in 2025."}
{"id":"era3d","title":"Era3D: High-Resolution Multiview Diffusion using Efficient Row-wise Attention","venue":"NeurIPS 2024","task":"image-to-3d","summary":"A multiview generation model that remained relevant in 2025 for single-image 3D asset pipelines.","paper":"https://arxiv.org/abs/2405.11616","repo":"https://github.com/pengHTYX/Era3D","open_source":true,"active_since":2025,"scope_note":"Kept because Era3D remained an active multiview generation component in 2025 image-to-3D stacks."}

