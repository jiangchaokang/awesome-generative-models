{"id":"uniugg","title":"UniUGG: Unified 3D Understanding and Generation via Geometric-Semantic Encoding","venue":"arXiv 2025","task":"general-scene-generation","summary":"A unified framework spanning 3D understanding and generation with shared geometric-semantic representations.","paper":"https://arxiv.org/abs/2508.11952"}
{"id":"flashworld","title":"FlashWorld: High-quality 3D Scene Generation within Seconds","venue":"arXiv 2025","task":"general-scene-generation","summary":"A fast 3D-oriented scene generator that directly predicts Gaussian representations from text or image prompts.","paper":"https://arxiv.org/abs/2510.13678"}
