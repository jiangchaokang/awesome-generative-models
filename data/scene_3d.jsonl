{"id":"disco-layout","title":"DisCo-Layout: Disentangling and Coordinating Semantic and Physical Refinement in a Multi-Agent Framework for 3D Indoor Layout Synthesis","venue":"arXiv 2025","task":"layout-to-scene","summary":"Uses coordinated semantic and physical refinement tools inside a multi-agent loop for indoor layout synthesis.","paper":"https://arxiv.org/abs/2510.02178","domain":["indoor"]}
{"id":"spatialgen","title":"SPATIALGEN: Layout-guided 3D Indoor Scene Generation","venue":"3DV 2026","task":"layout-to-scene","summary":"A multi-view multi-modal diffusion model for realistic 3D indoor scene generation from layout plus image reference.","paper":"https://arxiv.org/abs/2509.14981","domain":["indoor"]}
{"id":"flowscene","title":"FlowScene: Style-Consistent Indoor Scene Generation with Multimodal Graph Rectified Flow","venue":"arXiv 2026","task":"indoor","summary":"A graph-based rectified-flow approach to style-consistent indoor scene generation.","paper":"https://arxiv.org/abs/2603.19598","domain":["indoor"]}

# general-scene-generation / outdoor-urban / single-image-to-scene
{"id":"causalstruct","title":"Causal Reasoning Elicits Controllable 3D Scene Generation","venue":"arXiv 2025","task":"general-scene-generation","summary":"Injects causal graphs and interventions into scene generation for stronger logical and physical coherence.","paper":"https://arxiv.org/abs/2509.15249"}
